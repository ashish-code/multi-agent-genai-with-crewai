# ── LLM ─────────────────────────────────────────────────────────────────────
# CrewAI reads MODEL to select the LLM for all agents.
# Bedrock models require AWS credentials (see below).
# Alternative: openai/gpt-4o  anthropic/claude-3-5-sonnet-20241022  google/gemini-2.5-flash
MODEL=bedrock/amazon.nova-lite-v1:0

# ── AWS credentials (required for Bedrock LLM + Titan embeddings) ────────────
AWS_PROFILE=default
# Or set explicit keys:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ── RAG index ────────────────────────────────────────────────────────────────
# Path to directory containing index.faiss + chunks.parquet + meta.json.
# Copy from gas-and-energy-mechanics-copilot/data/rag_index/
# or set this to an absolute path pointing to that directory.
RAG_INDEX_DIR=data/rag_index

# ── Bedrock embedding model ───────────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_REGION=us-east-1

# ── Retrieval settings ────────────────────────────────────────────────────────
RAG_TOP_K=5
